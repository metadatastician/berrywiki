# BerryWiki environment — NAMES ONLY. Never put real values here.
# Copy to `.env` (git-ignored) and fill in locally, or use an approved secret
# store (e.g. reasonably-good-token-vault). See docs/decisions/0002-authentication-strategy.adoc

# Fine-grained GitHub PAT with Contents: read/write on the target wiki repo.
BERRYWIKI_GITHUB_TOKEN=

# owner/repo of the wiki's parent repository (the wiki lives at <repo>.wiki.git).
BERRYWIKI_WIKI_REPO=

# Optional: local working-clone cache directory (must be outside the repo).
BERRYWIKI_CACHE_DIR=
